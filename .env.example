# Resend API key for contact form email notifications
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Where contact form notifications should be sent
CONTACT_TO_EMAIL=you@example.com

# Optional sender address configured in Resend
# Example: noreply@yourdomain.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Notes:
# 1) Without RESEND_API_KEY and CONTACT_TO_EMAIL, submissions will still be saved locally.
# 2) After setting env vars, restart the app or redeploy on Vercel.
